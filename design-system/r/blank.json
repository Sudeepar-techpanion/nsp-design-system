    "theme",
    "nimble-sidebar",
    "nimble-header",
    "status-badge",
    "stat-card",
    "page-tabs",
    "button",
    "card",
    "input",
    "badge",
    "avatar",
    "dialog",
    "dropdown-menu",
    "table",
    "checkbox",
    "select",
    "tabs",
    "popover",
    "calendar",
    "tooltip",
    "sonner"
  ],
  "files": [
    {
      "path": "registry/layouts/shell-layout.tsx",
      "type": "registry:file",
      "target": "src/app/layout.tsx"
    },
    {
      "path": "registry/blocks/blank-page.tsx",
      "type": "registry:page",
      "target": "src/app/page.tsx"
